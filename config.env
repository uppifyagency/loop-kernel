# Defaults for the BUNDLED example runs (the product path uses each project's own
# .loop/loop.env, created by `loop init`). Every value can be overridden inline:
#   WORKER_CMD=workers/stub-noop.sh MAX_ITERS=5 ./kernel.sh

TASK_DIR=examples/roman

# The worker for ONE iteration. Swap these:
#   workers/stub-solve-on-2.sh  -> deterministic: proves SUCCESS stop
#   workers/stub-noop.sh        -> deterministic: proves NO-PROGRESS stop
#   workers/stub-stepwise.sh    -> deterministic: score climbs across iterations
#   workers/claude.sh           -> the REAL agent (`claude -p`)
WORKER_CMD=workers/stub-solve-on-2.sh

# The three hard stops
MAX_ITERS=10
NOPROGRESS_K=3
